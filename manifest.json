{
  "manifest_version": 3,
  "name": "YouTube Skip Controls",
  "version": "1.1",
  "description": "Skip YouTube videos by 5, 10, or 15 seconds — buttons embedded right in the player controls.",

  "browser_specific_settings": {
    "gecko": {
      "id": "yt-skip-controls@extension",
      "strict_min_version": "109.0"
    }
  },

  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
